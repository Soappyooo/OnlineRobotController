<?xml version="1.0" ?>
<!--
 Combined example URDF for Online Robot Controller.

 This file adapts content from two upstream robot descriptions already included
 in this repository:

 1. assets/ur5_shadow_example/urdf/ur5.urdf
   - Marked as MIT-licensed in its source file header.

 2. assets/ur5_shadow_example/urdf/shadow_hand_right.urdf
   - Distributed under the BSD License with copyright notice from
    Shadow Robot Company Ltd.

 Keep those upstream notices when redistributing this combined file.
 See THIRD_PARTY_NOTICES.md for the consolidated notice text.
-->
<robot name="ur5_shadow">
  <link name="world"/>
  <transmission name="ur5_shoulder_pan_trans">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="ur5_shoulder_pan_joint">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="ur5_shoulder_pan_motor">
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="ur5_shoulder_lift_trans">
